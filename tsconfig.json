{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@opencode-sync/shared": ["packages/shared/src"],
      "@opencode-sync/relay": ["packages/relay/src"],
      "@opencode-sync/mcp": ["packages/mcp/src"]
    }
  }
}
